# UKCR ortam ayarları örneği — kopyalayıp `.env` yapın ve doldurun.

# Üretimde Postgres'e geçmek için:
# DATABASE_URL=postgresql+psycopg://kullanici:sifre@host/db

# Reel getiri (enflasyona göre) için TCMB EVDS API anahtarı.
# Ücretsiz kayıt: https://evds3.tcmb.gov.tr  (Giriş -> profil -> API Anahtarı)
EVDS_API_KEY=

# Gecelik otomatik veri güncellemeyi uygulama içinde başlat:
# ENABLE_SCHEDULER=true
